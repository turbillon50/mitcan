// CSN — Carnes Selectas Nayarit
// Schema reconciled with the LIVE Neon database via runtime introspection
// (information_schema). The existing tables already hold real data — do NOT run
// `prisma migrate`. Prisma field names are kept app-friendly and @map'd to the
// real columns where they differ.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum user_role {
  admin
  gerente
  empleado
  cliente
  repartidor
}

model sucursales {
  id         Int       @id @default(autoincrement())
  nombre     String    @map("name")
  area       String
  direccion  String?   @map("address")
  telefono   String?   @map("phone")
  lat        Decimal?  @db.Decimal
  lng        Decimal?  @db.Decimal
  horario    String?   @default("8:00-20:00")
  whatsapp   String?
  activa     Boolean?  @default(true) @map("active")
  abierta    Boolean?  @default(true)
  radio_km   Decimal?  @default(100) @db.Decimal
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  inventario      inventario[]
  pedidos         pedidos[]
  users           users[]
  promociones     promociones[]
  precios_sucursal precios_sucursal[]

  @@map("sucursales")
}

model users {
  id          String     @id
  clerk_id    String     @unique
  email       String?    @unique
  nombre      String?    @map("name")
  telefono    String?    @map("phone")
  rol         user_role? @default(cliente) @map("role")
  sucursal_id Int?
  puntos         Int?       @default(0)
  numero_cliente  Int?       @default(autoincrement())
  nivel       String?    @default("bronce")
  direccion   String?
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)

  sucursal       sucursales?      @relation(fields: [sucursal_id], references: [id])
  pedidos        pedidos[]
  redenciones    redenciones[]
  notificaciones notificaciones[]
  encuestas      encuestas[]
  puntos_movs    puntos_movimientos[]
  mensajes       mensajes[]

  @@map("users")
}

model mensajes {
  id            Int       @id @default(autoincrement())
  user_id       String // cliente dueño de la conversación
  remitente     String // 'admin' | 'cliente'
  cuerpo        String
  autor_nombre  String?
  leido_admin   Boolean?  @default(false)
  leido_cliente Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@map("mensajes")
}

model categorias {
  id     Int      @id @default(autoincrement())
  nombre String   @map("name")
  slug   String
  icono  String?  @map("icon")
  orden  Int?     @default(0)
  activa Boolean? @default(true) @map("active")

  productos productos[]

  @@map("categorias")
}

model productos {
  id           Int       @id @default(autoincrement())
  nombre       String    @map("name")
  slug         String
  sku          String?   @unique
  descripcion  String?
  categoria_id Int?
  precio       Decimal   @db.Decimal
  unidad       String?   @default("kg")
  imagen_url   String?
  imagenes     Json?     @db.JsonB // galería de fotos (array de URLs); imagen_url = portada
  es_nuevo     Boolean?  @default(false)
  activo       Boolean?  @default(true) @map("disponible")
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  categoria        categorias?        @relation(fields: [categoria_id], references: [id])
  inventario       inventario[]
  pedido_items     pedido_items[]
  promociones      promociones[]
  precios_sucursal precios_sucursal[]

  @@map("productos")
}

model precios_sucursal {
  id          Int       @id @default(autoincrement())
  producto_id Int
  sucursal_id Int
  precio      Decimal?  @db.Decimal // null = usa precio base del producto
  activo      Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  producto productos  @relation(fields: [producto_id], references: [id], onDelete: Cascade)
  sucursal sucursales @relation(fields: [sucursal_id], references: [id], onDelete: Cascade)

  @@unique([producto_id, sucursal_id])
  @@map("precios_sucursal")
}

model content_blocks {
  id         Int       @id @default(autoincrement())
  key        String    @unique
  content    Json?     @db.JsonB
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("content_blocks")
}

model inventario {
  id          Int       @id @default(autoincrement())
  producto_id Int?
  sucursal_id Int?
  stock       Decimal?  @default(0) @db.Decimal
  min_stock   Decimal?  @default(5) @db.Decimal
  precio      Decimal?  @db.Decimal // precio específico por sucursal (override)
  fuente      String?   @default("manual") // manual | sync_externo
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  producto productos?  @relation(fields: [producto_id], references: [id])
  sucursal sucursales? @relation(fields: [sucursal_id], references: [id])

  @@map("inventario")
}

model promociones {
  id           Int       @id @default(autoincrement())
  titulo       String
  descripcion  String?
  tipo         String?   @default("descuento") // descuento|monto|2x1|envio|combo
  valor        Decimal?  @db.Decimal
  precio_promo Decimal?  @db.Decimal
  unidad       String?
  producto_id  Int?
  sucursal_id  Int?
  sucursales   String[]  @default([]) // IDs de sucursal o ['todas']
  orden        Int?      @default(0)
  fecha_inicio DateTime? @db.Timestamptz(6)
  fecha_fin    DateTime? @db.Timestamptz(6)
  imagen_url   String?
  activa       Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  producto productos?  @relation(fields: [producto_id], references: [id])
  sucursal sucursales? @relation(fields: [sucursal_id], references: [id])

  @@map("promociones")
}

model pedidos {
  id             Int       @id @default(autoincrement())
  folio          String    @map("numero")
  user_id        String?   @map("cliente_id")
  sucursal_id    Int?
  estado         String?   @default("nuevo") @map("status")
  subtotal       Decimal?  @db.Decimal
  descuento      Decimal?  @default(0) @db.Decimal
  total          Decimal?  @db.Decimal
  puntos_ganados Int?      @default(0)
  notas          String?
  tipo               String?   @default("mostrador") // mostrador | en_linea
  envio              Decimal?  @default(0) @db.Decimal
  metodo_pago        String?   @default("contra_entrega") // contra_entrega | tarjeta | transferencia | spei | qr (futuro)
  direccion_entrega  String?
  telefono_entrega   String?
  repartidor         String?   // nombre mostrado del repartidor
  repartidor_id      String?   // users.id del repartidor asignado
  asignado_at        DateTime? @db.Timestamptz(6)
  entregado_at       DateTime? @db.Timestamptz(6)
  entrega_confirmada Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)

  user     users?         @relation(fields: [user_id], references: [id])
  sucursal sucursales?    @relation(fields: [sucursal_id], references: [id])
  items    pedido_items[]
  eventos  pedido_eventos[]
  encuesta encuestas?

  @@map("pedidos")
}

model pedido_items {
  id              Int     @id @default(autoincrement())
  pedido_id       Int?
  producto_id     Int?
  cantidad        Decimal @db.Decimal
  precio_unitario Decimal @db.Decimal
  subtotal        Decimal @db.Decimal

  pedido   pedidos?   @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  producto productos? @relation(fields: [producto_id], references: [id])

  @@map("pedido_items")
}

model recompensas {
  id                Int      @id @default(autoincrement())
  nombre            String   @map("name")
  descripcion       String?
  puntos_requeridos Int
  tipo              String?  @default("descuento")
  valor             Decimal? @db.Decimal
  activa            Boolean? @default(true) @map("active")
  imagen_url        String?

  redenciones redenciones[]

  @@map("recompensas")
}

model redenciones {
  id            Int       @id @default(autoincrement())
  user_id       String?
  recompensa_id Int?
  puntos_usados Int
  estado        String?   @default("activa") @map("status")
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  user       users?       @relation(fields: [user_id], references: [id])
  recompensa recompensas? @relation(fields: [recompensa_id], references: [id])

  @@map("redenciones")
}

model notificaciones {
  id         Int       @id @default(autoincrement())
  user_id    String?
  titulo     String
  mensaje    String
  tipo       String?   @default("general")
  leida      Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  user users? @relation(fields: [user_id], references: [id])

  @@map("notificaciones")
}

model pedido_eventos {
  id         Int       @id @default(autoincrement())
  pedido_id  Int
  estado     String
  nota       String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  pedido pedidos @relation(fields: [pedido_id], references: [id], onDelete: Cascade)

  @@map("pedido_eventos")
}

model encuestas {
  id          Int       @id @default(autoincrement())
  pedido_id   Int       @unique
  user_id     String?
  completo    Boolean?
  estrellas   Int?
  comentarios String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  pedido pedidos @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  user   users?  @relation(fields: [user_id], references: [id])

  @@map("encuestas")
}

model puntos_movimientos {
  id          Int       @id @default(autoincrement())
  user_id     String
  pedido_id   Int?
  puntos      Int
  tipo        String?   @default("compra")
  descripcion String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  user users @relation(fields: [user_id], references: [id])

  @@map("puntos_movimientos")
}
