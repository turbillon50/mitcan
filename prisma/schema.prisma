// CSN — Carnes Selectas Nayarit
// Schema hand-authored to match the EXISTING Neon database (11 tables, real data).
// IMPORTANT: do NOT run `prisma migrate` against this DB — the tables already exist.
// To reconcile exact columns with the live database run:  npx prisma db pull
// (with DATABASE_URL pointing at the Neon instance), then `prisma generate`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum user_role {
  admin
  gerente
  empleado
  cliente
}

model sucursales {
  id            Int       @id @default(autoincrement())
  nombre        String
  area          String?
  direccion     String?
  telefono      String?
  lat           Float?
  lng           Float?
  horario       String?
  activa        Boolean   @default(true)
  created_at    DateTime  @default(now())

  inventario    inventario[]
  pedidos       pedidos[]
  users         users[]

  @@map("sucursales")
}

model users {
  id            Int       @id @default(autoincrement())
  clerk_id      String?   @unique
  email         String?   @unique
  nombre        String?
  telefono      String?
  rol           user_role @default(cliente)
  puntos        Int       @default(0)
  nivel         String?
  sucursal_id   Int?
  activo        Boolean   @default(true)
  created_at    DateTime  @default(now())

  sucursal      sucursales?     @relation(fields: [sucursal_id], references: [id])
  pedidos       pedidos[]
  redenciones   redenciones[]
  notificaciones notificaciones[]

  @@map("users")
}

model categorias {
  id          Int        @id @default(autoincrement())
  nombre      String
  slug        String?
  icono       String?
  orden       Int        @default(0)
  activa      Boolean    @default(true)

  productos   productos[]

  @@map("categorias")
}

model productos {
  id            Int       @id @default(autoincrement())
  nombre        String
  descripcion   String?
  categoria_id  Int?
  precio        Decimal   @default(0) @db.Decimal(10, 2)
  unidad        String?   @default("kg")
  imagen_url    String?
  destacado     Boolean   @default(false)
  activo        Boolean   @default(true)
  created_at    DateTime  @default(now())

  categoria     categorias?    @relation(fields: [categoria_id], references: [id])
  inventario    inventario[]
  pedido_items  pedido_items[]

  @@map("productos")
}

model inventario {
  id            Int       @id @default(autoincrement())
  producto_id   Int
  sucursal_id   Int
  stock         Decimal   @default(0) @db.Decimal(10, 2)
  precio        Decimal?  @db.Decimal(10, 2)
  disponible    Boolean   @default(true)
  updated_at    DateTime  @default(now()) @updatedAt

  producto      productos  @relation(fields: [producto_id], references: [id])
  sucursal      sucursales @relation(fields: [sucursal_id], references: [id])

  @@unique([producto_id, sucursal_id])
  @@map("inventario")
}

model pedidos {
  id            Int       @id @default(autoincrement())
  folio         String?   @unique
  user_id       Int?
  sucursal_id   Int?
  estado        String    @default("pendiente") // pendiente|confirmado|en_camino|entregado|cancelado
  tipo_entrega  String?   @default("recoger")   // recoger|domicilio
  direccion     String?
  subtotal      Decimal   @default(0) @db.Decimal(10, 2)
  total         Decimal   @default(0) @db.Decimal(10, 2)
  puntos_ganados Int      @default(0)
  notas         String?
  created_at    DateTime  @default(now())

  user          users?         @relation(fields: [user_id], references: [id])
  sucursal      sucursales?    @relation(fields: [sucursal_id], references: [id])
  items         pedido_items[]
  redenciones   redenciones[]

  @@map("pedidos")
}

model pedido_items {
  id              Int      @id @default(autoincrement())
  pedido_id       Int
  producto_id     Int?
  cantidad        Decimal  @default(1) @db.Decimal(10, 2)
  precio_unitario Decimal  @default(0) @db.Decimal(10, 2)
  subtotal        Decimal  @default(0) @db.Decimal(10, 2)

  pedido          pedidos    @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  producto        productos? @relation(fields: [producto_id], references: [id])

  @@map("pedido_items")
}

model recompensas {
  id                Int       @id @default(autoincrement())
  nombre            String
  descripcion       String?
  tipo              String?   @default("descuento") // cupon|descuento|envio|producto
  puntos_requeridos Int       @default(0)
  imagen_url        String?
  valido_hasta      DateTime?
  activa            Boolean   @default(true)
  created_at        DateTime  @default(now())

  redenciones       redenciones[]

  @@map("recompensas")
}

model redenciones {
  id            Int       @id @default(autoincrement())
  user_id       Int
  recompensa_id Int
  pedido_id     Int?
  estado        String    @default("activa") // activa|usada|expirada
  created_at    DateTime  @default(now())

  user          users       @relation(fields: [user_id], references: [id])
  recompensa    recompensas @relation(fields: [recompensa_id], references: [id])
  pedido        pedidos?    @relation(fields: [pedido_id], references: [id])

  @@map("redenciones")
}

model notificaciones {
  id          Int       @id @default(autoincrement())
  user_id     Int
  titulo      String
  mensaje     String?
  tipo        String?   @default("info")
  leida       Boolean   @default(false)
  created_at  DateTime  @default(now())

  user        users     @relation(fields: [user_id], references: [id])

  @@map("notificaciones")
}
