# Neon Postgres (set in Vercel) — pooled + direct
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Clerk (pk_live already configured in Vercel)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
# Comma-separated emails always promoted to admin on sign-in (owner bootstrap).
# If empty, the FIRST account to sign in becomes admin automatically.
CSN_ADMIN_EMAILS=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app/dashboard

# Resend
RESEND_API_KEY=re_xxx
RESEND_FROM="CSN <hola@carnesn.ink>"

# Stripe (optional)
STRIPE_SECRET_KEY=sk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
